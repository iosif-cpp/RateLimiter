{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "Postgres": {
    "SshTunnel": {
      "SshHost": "your-ssh-host.example.com",
      "SshPort": 22,
      "SshUsername": "your-ssh-username",
      "SshPassword": "your-ssh-password",
      "LocalHost": "localhost",
      "LocalPort": 5433,
      "RemoteHost": "remote-db-host",
      "RemotePort": 5432
    },
    "Database": {
      "Host": "localhost",
      "Port": 5432,
      "Username": "your-db-username",
      "Password": "your-db-password",
      "DatabaseName": "your-database-name"
    }
  }
}

